# Copy to .env.local and fill in real values. Never commit secrets.

# Database (Prisma / PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB"

# Field-level encryption for health-related lead fields (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=""

# NextAuth / Auth.js
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""

# Optional: bootstrap admin via scripts/create-admin-user.ts
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Hunter Baruch"

# Lead notification email (Resend) — see docs/RESEND.md
# API key: https://resend.com/api-keys
RESEND_API_KEY=""
# Where Hunter receives new-lead alerts
LEAD_NOTIFICATION_EMAIL=""
# FROM address — use onboarding@resend.dev for testing; verify your domain for production
LEAD_FROM_EMAIL=""
# Optional: base URL for admin links in emails (defaults to VERCEL_URL or siteConfig.url)
SITE_URL=""

# Cloudflare Turnstile (bot protection on quote / contact / schedule forms)
# Create a widget at https://dash.cloudflare.com/ → Turnstile
# Required in production — submissions fail closed without a valid token.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# COMPLIANCE ASSUMPTION: confirm retention months with E&O carrier (default 24)
LEAD_RETENTION_MONTHS="24"

# Optional bearer token for scheduled retention cleanup POST /api/admin/retention-cleanup
CRON_SECRET=""
